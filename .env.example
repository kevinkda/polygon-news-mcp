# ---------------------------------------------------------------------------
# polygon-news-mcp environment template.
#
# Polygon.io REQUIRES an API key on every request.  Sign up for a free
# account at https://polygon.io/dashboard/api-keys and paste your key
# below.
#
# Free tier:    5 requests per minute   ($0/mo)
# Starter:      ~25 requests per minute ($29/mo) — 5x free
# Developer:    much higher              ($79/mo)
#
# Copy this file to .env (which is gitignored) and edit the values below.
# ---------------------------------------------------------------------------

# REQUIRED — your Polygon.io API key.  Sent as `Authorization: Bearer ...`
# header (never embedded in URLs, so nothing the server logs can echo it).
POLYGON_API_KEY=

# OPTIONAL — override the per-minute rate limit.  Defaults to 5 (free-tier
# safe).  Hard cap is 1000.  If you upgrade your Polygon plan, raise this
# to match the published limit.
POLYGON_RATE_LIMIT_PER_MIN=5

# OPTIONAL — override the Polygon base URL (used by integration tests).
# Default: https://api.polygon.io
POLYGON_BASE_URL=https://api.polygon.io

# OPTIONAL — DuckDB cache toggles (default: enabled).
POLYGON_CACHE_ENABLED=1
POLYGON_CACHE_BYPASS=0

# OPTIONAL — log level (default: WARNING).
LOG_LEVEL=WARNING
